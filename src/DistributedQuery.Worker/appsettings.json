{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Grpc": "Warning"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "DistributedQuery.Worker",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Consul": {
    "Address": "http://localhost:8500",
    "ServiceName": "distributed-query-worker"
  },
  "Worker": {
    "NodeId": "worker-node-01",
    "GrpcPort": 5100,
    "HealthPort": 5101,
    "Address": "127.0.0.1",
    "ShardIndices": [0],
    "Version": "1.0.0",
    "Consul": {
      "Enabled": false,
      "HealthCheckIntervalSeconds": 10,
      "HealthCheckTimeoutSeconds": 5,
      "DeregisterCriticalServiceAfterSeconds": 30
    },
    "Execution": {
      "StreamChunkSize": 500,
      "CommandTimeoutSeconds": 25,
      "MaxConcurrentQueries": 10,
      "DrainTimeoutSeconds": 15
    },
    "Shards": {
      "0": "Data Source=:memory:"
    }
  }
}
