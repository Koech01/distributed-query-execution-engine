{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OpenTelemetry": {
    "ServiceName": "DistributedQuery.Api",
    "OtlpEndpoint": ""
  },
  "Authentication": {
    "Enabled": true,
    "Authority": "https://auth.internal/",
    "Audience": "dqee-api",
    "UseLocalJwtIssuer": true,
    "RequireHttpsMetadata": true,
    "JwtSigning": {
      "Issuer": "http://localhost:5281/",
      "Audience": "dqee-api",
      "AccessTokenLifetimeSeconds": 3600
    },
    "Email": {
      "Enabled": true,
      "MinPasswordLength": 12,
      "DefaultScopes": [ "query:read" ],
      "LockoutThreshold": 5,
      "LockoutDurationMinutes": 15
    },
    "RateLimit": {
      "PermitLimitPerIp": 10,
      "WindowSeconds": 60
    },
    "Google": {
      "Enabled": false,
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/auth/google/callback"
    },
    "GitHub": {
      "Enabled": false,
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/auth/github/callback"
    },
    "Frontend": {
      "CallbackUrl": "http://localhost:5173/auth/callback"
    }
  },
  "Api": {
    "MaxSqlLengthChars": 10000,
    "MaxParameters": 50,
    "MinTimeoutSeconds": 1,
    "MaxTimeoutSeconds": 120,
    "MaxNodes": 1000
  },
  "RateLimiting": {
    "MaxConcurrentRequests": 200,
    "QueueLimit": 50
  },
  "CoordinatorClient": {
    "BaseUrl": "http://localhost:5200",
    "RequestTimeoutMs": 120000
  },
  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false",
    "InstanceName": "dqee:"
  },
  "Consul": {
    "Address": "http://localhost:8500"
  },
  "RabbitMq": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "guest",
    "Password": "guest"
  }
}
