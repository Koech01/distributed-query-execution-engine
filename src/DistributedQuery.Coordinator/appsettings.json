{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "OpenTelemetry": {
    "ServiceName": "DistributedQuery.Coordinator",
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Redis": {
    "ConnectionString": "localhost:6379,abortConnect=false",
    "InstanceName": "dqee:"
  },
  "Consul": {
    "Address": "http://localhost:8500",
    "NodeCacheTtlSeconds": 5
  },
  "RabbitMq": {
    "Host": "localhost",
    "VirtualHost": "/",
    "Username": "guest"
  },
  "Messaging": {
    "EnableWorkerConsumer": false,
    "EnableCoordinatorConsumer": true,
    "CoordinatorPrefetchCount": 16
  },
  "WorkerRegistration": {
    "Enabled": false
  },
  "Coordinator": {
    "DefaultQueryTimeoutMs": 30000,
    "MaxQueryTimeoutMs": 120000,
    "PlanCacheTtlSeconds": 3600,
    "ResultCacheTtlSeconds": 300,
    "PartialFailurePolicy": "BestEffort",
    "MinimumShardCoverage": 0.8,
    "FanOut": {
      "MaxConcurrentWorkerCalls": 50,
      "PerWorkerTimeoutMs": 25000
    },
    "Resilience": {
      "RetryCount": 3,
      "RetryBaseDelayMs": 100,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerSamplingDurationSeconds": 30,
      "CircuitBreakerBreakDurationSeconds": 15
    }
  },
  "ShardMap": {
    "Tables": {
      "orders": {
        "ShardKey": "customer_id",
        "ShardCount": 4,
        "Strategy": "ConsistentHash"
      }
    }
  }
}
