# Environment variables for the web UI
#
# Run ./setup.sh from the repository root to create this file automatically.
# Full variable reference (backend + frontend): ../.env.example

# Vite dev proxy target for /queries, /health, /auth, and /admin
VITE_API_PROXY_TARGET=http://localhost:5281

# Set to false to bypass authentication route guards in local development
VITE_AUTH_ENABLED=true

# Route API calls through the Vite dev proxy (same origin) to avoid CORS issues
VITE_DEV_USE_PROXY=true

# Use same-origin in dev with VITE_DEV_USE_PROXY=true
VITE_API_BASE_URL=same-origin

# Hide OAuth buttons when the backend disables a provider
VITE_OAUTH_GOOGLE_ENABLED=true
VITE_OAUTH_GITHUB_ENABLED=true

# Optional prefilled login credentials for local development (disabled by default)
VITE_SEED_LOGIN_PREFILL_ENABLED=false
# VITE_SEED_LOGIN_ADMIN_EMAIL=admin@example.com
# VITE_SEED_LOGIN_ADMIN_PASSWORD=ChangeMe-Admin-12
# VITE_SEED_LOGIN_USER_EMAIL=user@example.com
# VITE_SEED_LOGIN_USER_PASSWORD=ChangeMe-User-12

# Optional observability links for the Operations page
VITE_GRAFANA_URL=http://localhost:3000
VITE_JAEGER_URL=http://localhost:16686

# Playwright E2E (optional)
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:5173
# PLAYWRIGHT_MOCK_API=false